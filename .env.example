# Database
DB_HOST=postgres # "postgres" if running in Docker, "localhost" when running locally
DB_PORT=5432
DB_NAME=coupon_service_db
DB_USER=coupon_service_user
DB_PASSWORD=change_me

# Security — default API key (change before deploying)
API_KEY=change_me

# Application
SERVER_PORT=8080

# Docker Compose port bindings (host-side)
APP_EXTERNAL_PORT=8080
DB_EXTERNAL_PORT=5432

# Postgres image version used in docker-compose
POSTGRES_VERSION=16

# MaxMind GeoLite2 — free account at https://www.maxmind.com/en/geolite2/signup
GEOIPUPDATE_ACCOUNT_ID=your_account_id
GEOIPUPDATE_LICENSE_KEY=your_license_key
