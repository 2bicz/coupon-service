# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coupon_service
DB_USER=coupon_user
DB_PASSWORD=your_db_password_here

# Security — default Spring Boot user (change before deploying)
SECURITY_USER_NAME=admin
SECURITY_USER_PASSWORD=your_admin_password_here

# Application
SERVER_PORT=8080

# Docker Compose port bindings (host-side)
APP_EXTERNAL_PORT=8080
DB_EXTERNAL_PORT=5432

# Postgres image version used in docker-compose
POSTGRES_VERSION=16
